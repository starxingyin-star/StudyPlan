.page {
  padding: 24rpx;
}

.hero-card {
  background: linear-gradient(160deg, #0f8c69, #2fbe8f);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(15, 140, 105, 0.22);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.94;
}

.hero-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-box {
  flex: 1;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 22rpx;
  padding: 18rpx 20rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.82;
}

.entry-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.entry-desc {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}
