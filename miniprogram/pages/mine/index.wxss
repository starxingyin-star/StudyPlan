.page {
  padding: 24rpx;
}

.hero-card {
  background: linear-gradient(160deg, #f7d8df, #efc4d1);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  color: #5f4657;
  box-shadow: 0 18rpx 40rpx rgba(239, 196, 209, 0.28);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #5f4657;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b7081;
}

.hero-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-box {
  flex: 1;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 22rpx;
  padding: 18rpx 20rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8b7081;
}

.entry-card,
.setup-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.invite-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #6b6f7d;
}

.entry-desc {
  margin-top: 12rpx;
  color: #9a92a8;
  font-size: 24rpx;
  line-height: 1.6;
}

.setup-input {
  width: 100%;
  box-sizing: border-box;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  background: #fbf4ee;
  border-radius: 16rpx;
  margin-top: 16rpx;
  color: #5b5f6d;
  font-size: 28rpx;
}

.setup-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.primary-action,
.secondary-action,
.small-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-action,
.secondary-action {
  width: 156rpx;
}

.primary-action {
  background: #9fd5c7;
  color: #ffffff;
}

.secondary-action,
.small-action {
  background: #f5efe7;
  color: #7f7a91;
}

.small-action {
  width: 104rpx;
  flex: 0 0 104rpx;
}

.invite-token-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.invite-token {
  color: #5f4657;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 44rpx;
  letter-spacing: 0;
  word-break: break-all;
}

.copy-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #eef7f4;
  color: #5f9d91;
  font-size: 22rpx;
  font-weight: 700;
  flex: 0 0 88rpx;
}
