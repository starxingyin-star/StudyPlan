<view class="page">
  <view class="hero-card">
    <view class="hero-title">{{overview.familyName}}</view>
    <view class="hero-desc">把学习计划、打卡、奖励和家庭 PK 放在一个地方。</view>
    <view class="hero-stats">
      <view class="stat-box">
        <view class="stat-value">{{overview.childCount}}</view>
        <view class="stat-label">孩子</view>
      </view>
      <view class="stat-box">
        <view class="stat-value">{{overview.rewardCount}}</view>
        <view class="stat-label">奖励</view>
      </view>
    </view>
  </view>

  <view class="entry-card" bindtap="goToWeeklyPlan">
    <view class="entry-title">本周计划</view>
    <view class="entry-desc">按孩子、按天安排任务，支持任务库和自定义任务。</view>
  </view>
  <view class="entry-card" bindtap="goToWeeklyReview">
    <view class="entry-title">周回顾</view>
    <view class="entry-desc">查看积分、完成率、坚持情况和家庭内 PK。</view>
  </view>
  <view class="entry-card" bindtap="goToFamily">
    <view class="entry-title">家庭成员</view>
    <view class="entry-desc">管理家庭名称、孩子和照看者。</view>
  </view>
  <view class="entry-card" bindtap="goToRewardSettings">
    <view class="entry-title">奖励规则</view>
    <view class="entry-desc">管理积分兑换项和奖励分值。</view>
  </view>
</view>
