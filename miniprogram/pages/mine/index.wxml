<view class="page">
  <view class="hero-card">
    <view class="hero-title">{{overview.familyName}}</view>
    <view class="hero-desc">把学习计划、打卡、奖励和家庭 PK 放在一个地方。</view>
    <view class="hero-stats">
      <view class="stat-box">
        <view class="stat-value">{{overview.childCount}}</view>
        <view class="stat-label">孩子</view>
      </view>
      <view class="stat-box">
        <view class="stat-value">{{overview.rewardCount}}</view>
        <view class="stat-label">奖励</view>
      </view>
    </view>
  </view>

  <view wx:if="{{needsFamilySetup}}" class="setup-card">
    <view class="entry-title">创建家庭</view>
    <view class="entry-desc">用当前微信创建自己的家庭空间，之后可以邀请家人加入。</view>
    <input class="setup-input" placeholder="家庭名称" value="{{familyNameDraft}}" bindinput="onFamilyNameDraftInput" />
    <input class="setup-input" password placeholder="家长密码，例如 2468" value="{{parentPinDraft}}" bindinput="onParentPinDraftInput" />
    <view class="setup-actions">
      <view class="primary-action" role="button" bindtap="onCreateFamily">创建家庭</view>
    </view>
  </view>

  <view wx:if="{{needsFamilySetup}}" class="setup-card">
    <view class="entry-title">加入家庭</view>
    <view class="entry-desc">输入家人分享给你的邀请码，加入同一个家庭空间。</view>
    <input class="setup-input" placeholder="6 位邀请码" maxlength="6" value="{{inviteTokenDraft}}" bindinput="onInviteTokenDraftInput" />
    <view class="setup-actions">
      <view class="secondary-action" role="button" bindtap="onJoinFamily">加入家庭</view>
    </view>
  </view>

  <view wx:if="{{!needsFamilySetup}}" class="entry-card invite-card">
    <view>
      <view class="entry-title">邀请家人</view>
      <view class="entry-desc">生成邀请码，让家人用自己的微信加入这个家庭。</view>
      <view wx:if="{{generatedInviteToken}}" class="invite-token-row">
        <view class="invite-token" role="button" bindtap="onCopyInviteToken">{{generatedInviteToken}}</view>
        <view class="copy-action" role="button" bindtap="onCopyInviteToken">复制</view>
      </view>
    </view>
    <view class="small-action" role="button" bindtap="onCreateInvite">生成</view>
  </view>

  <view wx:if="{{!needsFamilySetup}}" class="entry-card" bindtap="goToWeeklyPlan">
    <view class="entry-title">本周计划</view>
    <view class="entry-desc">按孩子、按天安排任务，支持任务库和自定义任务。</view>
  </view>
  <view wx:if="{{!needsFamilySetup}}" class="entry-card" bindtap="goToWeeklyReview">
    <view class="entry-title">周回顾</view>
    <view class="entry-desc">查看积分、完成率、坚持情况和家庭内 PK。</view>
  </view>
  <view wx:if="{{!needsFamilySetup}}" class="entry-card" bindtap="goToFamily">
    <view class="entry-title">家庭成员</view>
    <view class="entry-desc">管理家庭名称、孩子和照看者。</view>
  </view>
  <view wx:if="{{!needsFamilySetup}}" class="entry-card" bindtap="goToRewardSettings">
    <view class="entry-title">奖励规则</view>
    <view class="entry-desc">管理积分兑换项和奖励分值。</view>
  </view>
</view>
