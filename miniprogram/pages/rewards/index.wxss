.page {
  padding: 24rpx;
}

.hero {
  background: linear-gradient(160deg, #1c4a8f, #275fd8);
  color: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 18rpx 40rpx rgba(39, 95, 216, 0.22);
}

.hero-eyebrow {
  font-size: 22rpx;
  opacity: 0.82;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-score {
  margin-top: 18rpx;
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.94;
}

.section-title {
  margin: 8rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.card,
.reward-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.task-title {
  font-weight: 700;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.reward-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.reward-meta {
  color: #6b7280;
  font-size: 24rpx;
}

.reward-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 22rpx;
}

.reward-badge.active {
  background: #dcfce7;
  color: #166534;
}

.history-item + .history-item {
  margin-top: 16rpx;
}

.history-sub {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.pk-item + .pk-item {
  margin-top: 12rpx;
}
