.page {
  padding: 24rpx;
}

.section-title {
  margin: 16rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #6b6f7d;
}

.card,
.form-card,
.member-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.member-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.member-main {
  flex: 1;
  min-width: 0;
}

.member-actions {
  display: flex;
  justify-content: flex-end;
}

.strong {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: #5f4657;
}

.sub {
  color: #8f86a0;
  font-size: 24rpx;
}

.text-input {
  width: 100%;
  box-sizing: border-box;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  background: #fbf4ee;
  border-radius: 16rpx;
  margin-top: 12rpx;
  color: #5b5f6d;
  font-size: 28rpx;
}

.text-input.small {
  flex: 1;
  margin-top: 0;
}

.picker {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #fbf4ee;
  border-radius: 16rpx;
  color: #5b5f6d;
}

.mini-danger {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  width: 104rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #b7e3d4;
  color: #46665d;
  font-size: 22rpx;
}

.wide-btn,
.page-submit {
  width: 100%;
  margin-top: 18rpx;
}
