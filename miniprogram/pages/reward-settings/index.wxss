.page {
  padding: 24rpx;
}

.section-title {
  margin: 12rpx 0 16rpx;
  font-weight: 700;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.strong {
  font-weight: 700;
  margin-bottom: 8rpx;
}

.sub {
  color: #6b7280;
  font-size: 24rpx;
}

.text-input {
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
  margin-top: 12rpx;
}

.text-input.small {
  flex: 1;
  margin-top: 0;
}

.small-btn {
  margin: 0;
  font-size: 24rpx;
}
