.page {
  padding: 24rpx;
}

.tabs {
  display: flex;
  gap: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  background: #f3f4f6;
  color: #6b7280;
  border-radius: 20rpx;
  padding: 16rpx 0;
}

.tab.active {
  background: #dcfce7;
  color: #166534;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
