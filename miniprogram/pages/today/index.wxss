.page {
  padding: 24rpx;
}

.hero-card {
  background: linear-gradient(160deg, #bfe8d8, #a4d8c9);
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  color: #4a625a;
  box-shadow: 0 18rpx 40rpx rgba(164, 216, 201, 0.28);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.hero-eyebrow {
  font-size: 22rpx;
  opacity: 1;
  color: #6f8e84;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #45635b;
}

.hero-progress {
  min-width: 110rpx;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.45);
  color: #4a625a;
  font-size: 30rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5f7d72;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-box {
  background: rgba(255, 255, 255, 0.4);
  border-radius: 22rpx;
  padding: 20rpx;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #45635b;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6f8e84;
}

.section-title {
  margin: 8rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #6b6f7d;
}

.task-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.task-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.task-title {
  font-weight: 700;
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.task-meta {
  color: #7f7a91;
  font-size: 24rpx;
}

.status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f5efe7;
  color: #7f7a91;
  font-size: 22rpx;
}

.status.completed {
  background: #dff3e8;
  color: #709884;
}

.status.partial {
  background: #fff0c8;
  color: #ab8a54;
}

.status.missed {
  background: #f8dfe6;
  color: #a97984;
}

.status.pending {
  background: #f5efe7;
  color: #9a92a8;
}

.comment {
  margin-top: 12rpx;
  color: #7f7a91;
  font-size: 24rpx;
}

.task-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: #9fd5c7;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.task-panel {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e5e7eb;
}

.note-input {
  width: 100%;
  box-sizing: border-box;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: #fbf4ee;
  font-size: 28rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 16rpx -6rpx 0;
}

.small-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc(50% - 12rpx);
  box-sizing: border-box;
  margin: 6rpx;
  height: 52rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.empty-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  color: #7f7a91;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b6f7d;
}

.empty-desc {
  margin-top: 12rpx;
  line-height: 1.6;
  font-size: 24rpx;
}
