.page {
  padding: 24rpx;
}

.hero-card {
  background: linear-gradient(160deg, #1fb87c, #17885b);
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(23, 136, 91, 0.24);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.hero-eyebrow {
  font-size: 22rpx;
  opacity: 0.82;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.hero-progress {
  min-width: 110rpx;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 30rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.94;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-box {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 22rpx;
  padding: 20rpx;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.82;
}

.section-title {
  margin: 8rpx 0 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.task-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.task-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.task-title {
  font-weight: 700;
  font-size: 30rpx;
  margin-bottom: 8rpx;
}

.task-meta {
  color: #6b7280;
  font-size: 24rpx;
}

.status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 22rpx;
}

.status.completed {
  background: #dcfce7;
  color: #166534;
}

.status.partial {
  background: #fef3c7;
  color: #92400e;
}

.status.missed {
  background: #fee2e2;
  color: #991b1b;
}

.status.pending {
  background: #f3f4f6;
  color: #6b7280;
}

.comment {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.action-btn {
  margin-top: 16rpx;
}

.task-panel {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e5e7eb;
}

.note-input {
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.small-action {
  margin: 0;
  font-size: 24rpx;
}

.empty-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  color: #4b5563;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.empty-desc {
  margin-top: 12rpx;
  line-height: 1.6;
  font-size: 24rpx;
}
