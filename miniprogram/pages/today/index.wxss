.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-title,
.task-title {
  font-weight: 700;
  margin-bottom: 12rpx;
}

.task-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 22rpx;
}

.status.completed {
  background: #dcfce7;
  color: #166534;
}

.status.partial {
  background: #fef3c7;
  color: #92400e;
}

.status.missed {
  background: #fee2e2;
  color: #991b1b;
}

.status.pending {
  background: #f3f4f6;
  color: #6b7280;
}

.comment {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.action-btn {
  margin-top: 16rpx;
}

.task-panel {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e5e7eb;
}

.note-input {
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.small-action {
  margin: 0;
  font-size: 24rpx;
}
