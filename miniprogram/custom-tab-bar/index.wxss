.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0 28rpx calc(env(safe-area-inset-bottom) + 18rpx);
  background: linear-gradient(180deg, rgba(251, 247, 242, 0) 0%, rgba(251, 247, 242, 0.92) 36%, rgba(251, 247, 242, 1) 100%);
  z-index: 999;
}

.tab-bar {
  display: flex;
  gap: 12rpx;
  background: rgba(255, 251, 248, 0.96);
  border-radius: 999rpx;
  padding: 12rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.12);
  backdrop-filter: blur(12px);
}

.tab-item {
  flex: 1;
  min-height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: #7b768d;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: linear-gradient(160deg, #b7e3d4, #9fd3c3);
  color: #46665d;
  box-shadow: 0 8rpx 20rpx rgba(159, 211, 195, 0.28);
}

.tab-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}
