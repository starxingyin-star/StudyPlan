.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0 28rpx calc(env(safe-area-inset-bottom) + 18rpx);
  background: linear-gradient(180deg, rgba(248, 247, 241, 0) 0%, rgba(248, 247, 241, 0.92) 36%, rgba(248, 247, 241, 1) 100%);
  z-index: 999;
}

.tab-bar {
  display: flex;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 999rpx;
  padding: 12rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.12);
  backdrop-filter: blur(12px);
}

.tab-item {
  flex: 1;
  min-height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: #6b7280;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: linear-gradient(160deg, #1fb87c, #17885b);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(23, 136, 91, 0.22);
}

.tab-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}
