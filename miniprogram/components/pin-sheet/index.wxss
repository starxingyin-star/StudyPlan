.mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.45);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
}

.title {
  font-weight: 700;
  margin-bottom: 20rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}
